{
  "inputs": [
    {
      "type": "promptString",
      "id": "scrapebadger-api-key",
      "description": "ScrapeBadger API Key",
      "password": true
    }
  ],
  "servers": {
    "skiplagged": {
      "type": "http",
      "url": "https://mcp.skiplagged.com/mcp",
      "headers": {}
    },
    "kiwi": {
      "type": "http",
      "url": "https://mcp.kiwi.com",
      "headers": {}
    },
    "trivago": {
      "type": "http",
      "url": "https://mcp.trivago.com/mcp",
      "headers": {}
    },
    "ferryhopper": {
      "type": "http",
      "url": "https://mcp.ferryhopper.com/mcp",
      "headers": {}
    },
    "scrapebadger": {
      "type": "http",
      "url": "https://mcp.scrapebadger.com/mcp",
      "headers": {
        "Authorization": "Bearer ${scrapebadger-api-key}"
      }
    },
    "twitter-mcp": {
      "command": "npx",
      "args": ["-y", "@enescinar/twitter-mcp"],
      "env": {
        "API_KEY": "<api_key>",
        "API_SECRET_KEY": "<api_secret_key>",
        "ACCESS_TOKEN": "<access_token>",
        "ACCESS_TOKEN_SECRET": "<access_token_secret>"
      }
    }
  }
}
